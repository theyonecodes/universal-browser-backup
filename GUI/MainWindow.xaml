<Window x:Class="UniversalBrowserBackup.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Universal Browser Backup v2.1"
        Height="620" Width="820"
        WindowStartupLocation="CenterScreen"
        Background="#FF1E1E2E"
        Foreground="#FFCDD6F4"
        FontFamily="Segoe UI"
        ResizeMode="CanMinimize">

    <Window.Resources>
        <SolidColorBrush x:Key="BaseColor" Color="#FF1E1E2E"/>
        <SolidColorBrush x:Key="SurfaceColor" Color="#FF313244"/>
        <SolidColorBrush x:Key="OverlayColor" Color="#FF45475A"/>
        <SolidColorBrush x:Key="PrimaryColor" Color="#FF89B4FA"/>
        <SolidColorBrush x:Key="SecondaryColor" Color="#FFA6E3A1"/>
        <SolidColorBrush x:Key="WarningColor" Color="#FFF9E2AF"/>
        <SolidColorBrush x:Key="ErrorColor" Color="#FFF38BA8"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#FFCDD6F4"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#FFBAC2DE"/>
        <SolidColorBrush x:Key="TextDim" Color="#FF6C7086"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="UB" FontSize="28" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{StaticResource PrimaryColor}"/>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Universal Browser Backup" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                <TextBlock Text="Auto-detect | Multi-profile | Integrity verified" FontSize="12" Foreground="{StaticResource TextDim}"/>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource SurfaceColor}" CornerRadius="8" Padding="12" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="DETECTED BROWSERS" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextDim}" Margin="0,0,0,8"/>

                    <CheckBox x:Name="chkSelectAll" Grid.Row="1" Content="Select All"
                              Foreground="{StaticResource TextPrimary}" Margin="0,0,0,8"
                              IsChecked="True"/>

                    <ListBox x:Name="lstBrowsers" Grid.Row="2"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{StaticResource TextPrimary}"
                             SelectionMode="Extended">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="{Binding ProfileCountLabel}" Foreground="{StaticResource TextDim}" FontSize="11"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Button x:Name="btnRefresh" Grid.Row="3" Content="Refresh List"
                            Background="{StaticResource OverlayColor}" Foreground="{StaticResource TextPrimary}"
                            Height="32" Margin="0,8,0,0"
                            BorderThickness="0" Cursor="Hand"/>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                    <RadioButton x:Name="radBackup" Content="Backup" GroupName="Mode"
                                 Foreground="{StaticResource TextPrimary}" FontSize="14" FontWeight="SemiBold"
                                 IsChecked="True" Margin="0,0,20,0"/>
                    <RadioButton x:Name="radRestore" Content="Restore" GroupName="Mode"
                                 Foreground="{StaticResource TextPrimary}" FontSize="14" FontWeight="SemiBold"/>
                </StackPanel>

                <Border Grid.Row="1" Background="{StaticResource SurfaceColor}" CornerRadius="8" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="Destination" Foreground="{StaticResource TextDim}" FontSize="11" Margin="0,0,0,4"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="txtDestination" Grid.Column="0"
                                         Background="{StaticResource OverlayColor}" Foreground="{StaticResource TextPrimary}"
                                         BorderThickness="0" Height="32" Padding="8,4"
                                         IsReadOnly="True" VerticalContentAlignment="Center"/>
                                <Button x:Name="btnBrowse" Grid.Column="1" Content="Browse..."
                                        Background="{StaticResource PrimaryColor}" Foreground="{StaticResource BaseColor}"
                                        FontWeight="SemiBold" Height="32" Margin="8,0,0,0" Padding="16,0"
                                        BorderThickness="0" Cursor="Hand"/>
                            </Grid>
                        </StackPanel>

                        <TextBlock Grid.Row="1" Text="Activity Log" Foreground="{StaticResource TextDim}"
                                   FontSize="11" Margin="0,0,0,4"/>
                        <TextBox x:Name="txtLog" Grid.Row="2"
                                 Background="{StaticResource BaseColor}" Foreground="{StaticResource TextSecondary}"
                                 BorderThickness="0" Padding="8"
                                 FontSize="11" IsReadOnly="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"/>
                    </Grid>
                </Border>

                <Grid Grid.Row="2" Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ProgressBar x:Name="progressBar" Grid.Row="0" Height="6"
                                 Background="{StaticResource OverlayColor}"
                                 Foreground="{StaticResource PrimaryColor}"
                                 Maximum="100" Value="0" Margin="0,0,0,4"/>

                    <TextBlock x:Name="txtProgress" Grid.Row="1"
                               Foreground="{StaticResource TextDim}" FontSize="11" Margin="0,0,0,10"/>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="txtStatus" Grid.Column="0"
                                   Foreground="{StaticResource SecondaryColor}" FontSize="12"
                                   VerticalAlignment="Center"/>

                        <Button x:Name="btnCancel" Grid.Column="1" Content="Cancel"
                                Background="Transparent" Foreground="{StaticResource ErrorColor}"
                                BorderBrush="{StaticResource ErrorColor}" BorderThickness="1"
                                Height="36" Padding="20,0" Margin="0,0,10,0"
                                Visibility="Collapsed" Cursor="Hand"/>

                        <Button x:Name="btnAction" Grid.Column="2" Content="Start Backup"
                                Background="{StaticResource PrimaryColor}" Foreground="{StaticResource BaseColor}"
                                FontWeight="SemiBold" FontSize="14" Height="36" Padding="24,0"
                                BorderThickness="0" Cursor="Hand"/>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <TextBlock Grid.Row="3" Text="v2.1 - MIT License"
                   Foreground="{StaticResource TextDim}" FontSize="10"
                   HorizontalAlignment="Center" Margin="0,12,0,0"/>
    </Grid>
</Window>